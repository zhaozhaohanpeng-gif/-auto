-- 1. 核心提速模块：本地缓存 + CDN 镜像
local function GetLibrary(FileName, URL)
    -- Xeno 兼容的文件读写判断
    if isfile(FileName) then
        return loadstring(readfile(FileName))()
    end
    -- 使用加速镜像站，解决江苏访问 GitHub 慢的问题
    local FastURL = URL:gsub("raw.githubusercontent.com", "fastly.jsdelivr.net/gh"):gsub("/master/", "@master/")
    local success, content = pcall(function() return game:HttpGet(FastURL) end)
    if success then
        writefile(FileName, content)
        return loadstring(content)()
    else
        -- 保底方案
        return loadstring(game:HttpGet(URL))()
    end
end

