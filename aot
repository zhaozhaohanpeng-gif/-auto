-- 5. 动态提速函数：购买工具优化 (不再死等 20 秒)
local function BuyToolOptimized(toolName)
    local events = ReplicatedStorage:WaitForChild("Events", 5)
    if not events then return end
    
    StatusText = "正在尝试购买: " .. toolName
    pcall(function()
        -- 针对原脚本中的远程事件调用
        events:WaitForChild("SSHPRMTE1"):InvokeServer(toolName, 1)
    end)
    
    local start = tick()
    -- 毫秒级轮询：一旦工具到手立刻继续，最长只等 3 秒
    repeat task.wait(0.1) until LocalPlayer.Backpack:FindFirstChild(toolName) or (tick() - start > 3)
    StatusText = "工具已准备就绪"
end

